{
	"name": "@family-manager/api",
	"version": "0.1.0",
	"private": true,
	"main": "dist/index.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"build": "tsc -p tsconfig.build.json",
		"start": "node dist/index.js",
		"test": "vitest",
		"lint": "biome lint .",
		"format": "biome check --write .",
		"format:check": "biome ci ."
	},
	"dependencies": {
		"express": "^4.19.0",
		"cors": "^2.8.5",
		"zod": "^3.23.0",
		"@prisma/client": "^5.15.0"
	},
	"devDependencies": {
		"prisma": "^5.15.0",
		"typescript": "^5.6.0",
		"ts-node-dev": "^2.0.0",
		"@types/express": "^4.17.21",
		"@types/node": "^20.11.0",
		"vitest": "^1.6.0",
		"@biomejs/biome": "^1.9.0"
	},
	"prisma": {
		"schema": "../../prisma/schema/schema.prisma"
	}
}
