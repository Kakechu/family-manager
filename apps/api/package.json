{
	"name": "@family-manager/api",
	"version": "0.1.0",
	"private": true,
	"main": "dist/index.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/index.ts",
		"build": "tsc -p tsconfig.build.json",
		"start": "node dist/index.js",
		"test": "vitest",
		"lint": "biome lint .",
		"format": "biome check --write .",
		"format:check": "biome ci ."
	},
	"dependencies": {
		"@family-manager/shared": "0.1.0",
		"@prisma/client": "^5.15.0",
		"bcryptjs": "^3.0.3",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"express": "^4.19.0",
		"jsonwebtoken": "^9.0.3",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20.11.0",
		"@types/supertest": "^7.2.0",
		"prisma": "^5.15.0",
		"supertest": "^7.2.2",
		"typescript": "^5.6.0",
		"vitest": "^1.6.0"
	},
	"prisma": {
		"schema": "../../prisma/schema/schema.prisma"
	}
}
